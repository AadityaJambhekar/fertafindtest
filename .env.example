# Public browser configuration
VITE_RECAPTCHA_SITE_KEY=your_google_recaptcha_site_key

# Google Maps (public BROWSER key — safe to ship to the client, but MUST be restricted).
# In Google Cloud Console:
#   1. Enable: Maps JavaScript API, Places API, Geocoding API.
#   2. Create an API key and restrict it by HTTP referrer to your domains only,
#      e.g. https://www.fertafind.com/*, https://fertafind.com/*, http://localhost:8080/*
#   3. Restrict the key by API to the three services above.
# Never commit a real key. Leave blank to fall back to OpenStreetMap-based search.
VITE_GOOGLE_MAPS_API_KEY=your_browser_maps_api_key
# Optional Map ID for a cloud-styled/vector map (Maps JS "Map ID"). Leave blank for the default raster map.
VITE_GOOGLE_MAP_ID=your_optional_map_id

# Server-only secrets — never prefix these with VITE_ and never commit your real .env file.
# Create a project key at https://platform.openai.com/api-keys and paste the complete key after =
OPENAI_API_KEY=
# This model handles the quote images/PDFs and returns structured fertilizer data.
OPENAI_QUOTE_MODEL=gpt-5.6-luna
RECAPTCHA_SECRET_KEY=your_google_recaptcha_secret_key
RECAPTCHA_HOSTNAME=fertafind.com

# Optional partner-supplier database. Leave blank until a supplier database is connected.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
